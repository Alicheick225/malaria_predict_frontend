# Modèle des secrets Streamlit pour MalariaWatch CI.
#
# En local : copiez ce fichier en `.streamlit/secrets.toml` (ignoré par git) et
# renseignez l'URL de votre backend.
#
# Sur Streamlit Community Cloud : ouvrez votre app > Settings > Secrets, et collez
# le même contenu (avec l'URL de votre service Render) dans l'éditeur de secrets.

BACKEND_URL = "https://malaria-predict-backend.onrender.com"
